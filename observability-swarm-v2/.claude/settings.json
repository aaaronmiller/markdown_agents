    "log-aggregator": {
      "model": "haiku",
      "thinking_budget": 3000,
      "tools": ["filesystem", "fetch", "memory"],
      "skills": [],
      "priority": "high"
    },
    "trace-analyzer": {
      "model": "sonnet",
      "thinking_budget": 8000,
      "tools": ["fetch", "memory"],
      "skills": [],
      "priority": "high"
    },
    "anomaly-detector": {
      "model": "sonnet",
      "thinking_budget": 10000,
      "tools": ["memory"],
      "skills": [],
      "priority": "critical"
    },
    "slo-tracker": {
      "model": "haiku",
      "thinking_budget": 3000,
      "tools": ["memory"],
      "skills": [],
      "priority": "medium"
    },
    "incident-responder": {
      "model": "opus",
      "thinking_budget": 15000,
      "tools": ["github", "memory"],
      "skills": ["code-review"],
      "priority": "critical"
