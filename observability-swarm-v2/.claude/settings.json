{
  "model": "claude-sonnet-4-20250514",
  "thinking_budget": 12000,
  "agent_toolkit": {
    "enabled": true,
    "root": "../agent-toolkit"
  },
  "swarm_config": {
    "name": "observability-swarm-v2",
    "version": "2.0.0",
    "max_parallel_agents": 4
